# .env.example — Variables de entorno para Lensware Pro
# En Replit: configura UPLOAD_SECRET en la pestaña Secrets, NO en este archivo.
# Este archivo es solo de referencia.

# ── Replit (configurado automáticamente en el workflow) ───────────────────────
# APP_ENV=railway
# TMP_BASE=/home/runner/workspace/data

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Token para subidas externas desde push_to_replit.ps1
# Configurar en Replit Secrets → UPLOAD_SECRET
# UPLOAD_SECRET=tu_token_aqui

# ── Opcionales ────────────────────────────────────────────────────────────────
# Tiempo de vida del cache en segundos (default: 30)
# CACHE_TTL=30

# Máximo de días de histórico de backups (default: 365)
# BACKUP_RANGE_MAX_DAYS=365
